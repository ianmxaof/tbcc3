{
  "manifest_version": 3,
  "name": "TBCC Importer",
  "version": "1.17.0",
  "icons": {
    "16": "icons/icon16.png"
  },
  "permissions": ["contextMenus", "activeTab", "tabs", "storage", "notifications", "scripting", "sidePanel", "downloads", "cookies"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "http://127.0.0.1:5173/*",
    "http://localhost:5173/*",
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; frame-src 'self' http://127.0.0.1:5173 http://localhost:5173;"
  },
  "action": {
    "default_title": "TBCC Importer (click: gallery side panel)"
  },
  "options_ui": {
    "page": "model-search-options.html",
    "open_in_tab": true
  },
  "side_panel": {
    "default_path": "gallery.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["page-overlay.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
