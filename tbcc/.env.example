# Telegram API (my.telegram.org)
API_ID=your_telegram_api_id
API_HASH=your_telegram_api_hash

# Admin bot (get your ID from @userinfobot)
ADMIN_TELEGRAM_ID=your_telegram_user_id

# Payment bot (create via @BotFather)
BOT_TOKEN=your_bot_token_from_botfather

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./tbcc.db
# With Docker (tbcc/infra): docker compose up -d postgres redis
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tbcc

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Celery poster worker (scheduled posts / pool albums): Telethon session basename — file is {name}.session in cwd (usually tbcc/backend).
# Must already be logged in; workers do NOT prompt for phone (use the same account as admin or copy admin.session → admin_poster.session).
# TBCC_POSTER_TELEGRAM_SESSION=admin_poster
# Dev: auto-seed poster session from admin.session when poster is not authorized (SQLite backup; run Celery cwd = tbcc/backend).
# TBCC_POSTER_AUTO_COPY_ADMIN_SESSION=1
# After this many consecutive failed sends, a scheduled job is auto-paused (beat skips it). Set 0 to disable.
# TBCC_SCHED_POST_AUTO_PAUSE_STREAK=5

# Backend URL (for payment bot when not localhost)
# TBCC_API_URL=http://localhost:8000

# External payments (wallet / Cash App / crypto — admin marks paid in API)
# Shared secret: payment bot sends X-TBCC-Internal-Key on POST /external-payment-orders/
# Generate a long random string; set the same value for API + bot environments.
# TBCC_INTERNAL_API_KEY=
#
# Optional HTML template for instructions (placeholders: {reference_code} {plan_name} {price_stars})
# TBCC_EXTERNAL_PAY_TEMPLATE=<b>Pay</b> — memo: <code>{reference_code}</code> …

# --- Public URLs for Telegram (HTTPS, no trailing slash) ---
# After **Upload** in Bots → Shop products, the API builds: {TBCC_PROMO_PUBLIC_BASE_URL}/static/promo/...
# Set this to your tunnel or live API so Telegram can fetch images (localhost never works for the bot).
# TBCC_PROMO_PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.app
#
# Fallback if TBCC_PROMO_PUBLIC_BASE_URL is unset (same purpose, older name):
# TBCC_PUBLIC_BASE_URL=https://api.example.com

# Optional: override directory for uploaded promo images (default: tbcc/uploads/promo)
# TBCC_PROMO_DIR=C:/path/to/tbcc/uploads/promo

# Payment bot /shop promo (optional — HTTPS image URLs; override hero copy)
# SHOP_HERO_IMAGE_URL=https://example.com/hero.jpg
# SHOP_HERO_CAPTION=Your markdown caption...
# SHOP_SUBSCRIPTION_IMAGE_URL=
# SHOP_PACKS_IMAGE_URL=
# SHOP_SUBSCRIPTION_CAPTION=
# SHOP_PACKS_CAPTION=

# Optional: absolute path where bundle .zip files are stored (backend + payment bot must match)
# TBCC_BUNDLE_DIR=C:/path/to/tbcc/uploads/bundles

# Referral (for /referral command)
# REFERRAL_GROUP_INVITE_LINK=https://t.me/joinchat/xxx
# REFERRAL_GROUP_NAME=Our Community
# REFERRAL_REWARD_DAYS=7
# REFERRAL_MODE=community (no premium yet) | premium (subscription rewards)

# --- Growth: milestone “progress” line in group (optional; sent after each new subscription) ---
# Telegram chat id (often negative), e.g. -1001234567890 — bot must be able to post here.
# MILESTONE_PROGRESS_CHAT_ID=

# --- Daily AOF landing bulletin (Celery Beat, UTC hour) — referrals + milestone copy ---
# TBCC_LANDING_BULLETIN_CHAT_ID=-100xxxxxxxxxx
# Optional forum topic id if the “landing” lives in a topic:
# TBCC_LANDING_BULLETIN_MESSAGE_THREAD_ID=12345
# TBCC_LANDING_BULLETIN_HOUR_UTC=14
# TBCC_LANDING_BULLETIN_BOT_USERNAME=YourBotName
# Optional: full intro (multiline). If unset, a default AOF blurb is used.
# TBCC_LANDING_BULLETIN_INTRO=🔥 Welcome...\n\nLine two...

# --- LLM (Dashboard → shop AI, Media Library “AI suggest”) ---
# OpenAI: https://platform.openai.com/api-keys — prefer TBCC_OPENAI_API_KEY; OPENAI_API_KEY is an alternate name.
# TBCC_OPENAI_API_KEY=
# OPENAI_API_KEY=
# Optional model (default in code: gpt-4o-mini)
# TBCC_LLM_MODEL=gpt-4o-mini

# Vision auto-tag on import (Celery): after rule-based tags, queue OpenAI vision to assign tags from your /tags catalog.
# Requires Redis + Celery worker + TBCC_OPENAI_API_KEY. Skips video/documents in worker (photos/gif only).
# TBCC_AUTO_TAG_ON_IMPORT=1
# Optional max edge for downscaled image sent to OpenAI (default 1024)
# TBCC_AUTO_TAG_MAX_EDGE=1024

# After vision auto-tag (or tag rule re-apply): assign media.pool_id from pools with route rules.
# Each pool may set comma-separated tag slugs (tbcc_tags.slug) and/or NSFW tiers (sfw,suggestive,explicit,unknown).
# If both are set on a pool, BOTH must match. Tier-only or slug-only rules are allowed. Lower route_priority wins.
# Only when pool_id is unset unless TBCC_AUTO_ROUTE_OVERWRITE=1.
# TBCC_AUTO_ROUTE_POOL=1
# TBCC_AUTO_ROUTE_OVERWRITE=0

# Local OpenAI-compatible API key (LM Studio, Ollama with auth, etc.) — for future use or custom tooling.
# TBCC_LOCAL_LLM_API_KEY=
# Optional base URL when the backend supports pointing chat completions at localhost (not wired yet).
# TBCC_LOCAL_LLM_BASE_URL=http://127.0.0.1:1234/v1

# --- Automatic crypto (NOWPayments) + generic payment webhooks ---
# When all required vars are set, GET /health returns "crypto_auto_checkout": true and the payment bot shows
# Wallet/crypto users a hosted pay link; POST /webhooks/nowpayments fulfills orders (no dashboard mark-paid).
#
# 1) TBCC_PUBLIC_API_BASE_URL — public https:// base of THIS API (no trailing slash). NOWPayments must reach
#    {TBCC_PUBLIC_API_BASE_URL}/webhooks/nowpayments — use ngrok/Cloudflare Tunnel in dev (not localhost).
# 2) TBCC_NOWPAYMENTS_API_KEY — from NOWPayments dashboard.
# 3) TBCC_NOWPAYMENTS_IPN_SECRET — same as “IPN secret” in NOWPayments; must match what they send in X-NOWPAYMENTS-SIG.
# 4) In NOWPayments, set the IPN callback URL to: {TBCC_PUBLIC_API_BASE_URL}/webhooks/nowpayments
# 5) TBCC_INTERNAL_API_KEY — must match on payment bot so POST /external-payment-orders/ succeeds.
#
# TBCC_PUBLIC_API_BASE_URL=https://your-api.example.com
# TBCC_NOWPAYMENTS_API_KEY=
# TBCC_NOWPAYMENTS_IPN_SECRET=
# TBCC_NOWPAYMENTS_PAY_CURRENCY=usdttrc20   # pay_currency for /v1/payment
# TBCC_STARS_USD_PER_STAR=0.012            # heuristic: Stars list price → USD for NP quote
# Optional: POST /webhooks/instant-payment with Authorization: Bearer <secret> JSON {"reference_code":"EPO-…"}
# TBCC_PAYMENT_WEBHOOK_SECRET=
#
# Payment bot username (optional — for legacy Telethon subscription_bot redirect only)
# TBCC_PAYMENT_BOT_USERNAME=aofsubscriptions_bot
